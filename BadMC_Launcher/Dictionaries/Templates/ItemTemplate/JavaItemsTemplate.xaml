<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Interactivity="using:Microsoft.Xaml.Interactivity">
    <DataTemplate x:Key="JavaItemsTemplateSecondary">
        <Grid Background="Transparent" ToolTipService.ToolTip="{Binding JavaPath}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="48" />
            </Grid.ColumnDefinitions>

            <!-- Show tools -->
            <Interactivity:Interaction.Behaviors>
                <Interactivity:EventTriggerBehavior EventName="PointerEntered">
                    <Interactivity:ChangePropertyAction PropertyName="Opacity"
                                                        TargetObject="{Binding ElementName=MoreOptionsButton}"
                                                        Value="1" />
                    <Interactivity:ChangePropertyAction PropertyName="IsHitTestVisible"
                                                        TargetObject="{Binding ElementName=MoreOptionsButton}"
                                                        Value="True" />
                </Interactivity:EventTriggerBehavior>
                <Interactivity:EventTriggerBehavior EventName="PointerExited">
                    <Interactivity:ChangePropertyAction PropertyName="Opacity"
                                                        TargetObject="{Binding ElementName=MoreOptionsButton}"
                                                        Value="0" />
                    <Interactivity:ChangePropertyAction PropertyName="IsHitTestVisible"
                                                        TargetObject="{Binding ElementName=MoreOptionsButton}"
                                                        Value="False" />
                </Interactivity:EventTriggerBehavior>
            </Interactivity:Interaction.Behaviors>

            <Border x:Name="IconBorder"
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    Width="48"
                    Height="48"
                    Margin="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="4"
                    CornerRadius="8">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding JavaIconPath}" Stretch="UniformToFill">
                        <Interactivity:Interaction.Behaviors>
                            <Interactivity:EventTriggerBehavior EventName="ImageFailed">
                                <Interactivity:ChangePropertyAction PropertyName="ImageSource"
                                                                    Value="ms-appx:///Assets/Icons/JavaIcons/openjdk.png" />
                            </Interactivity:EventTriggerBehavior>
                        </Interactivity:Interaction.Behaviors>
                    </ImageBrush>
                </Border.Background>
            </Border>

            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Margin="6,6,0,0"
                        Orientation="Horizontal"
                        Spacing="8">
                <!-- Java id -->
                <TextBlock Height="30"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           Text="{Binding JavaId}"
                           TextTrimming="CharacterEllipsis" />

                <!-- Java type -->
                <Border VerticalAlignment="Center"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4">
                    <TextBlock Margin="4,2"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Text="{Binding JavaType}"
                               TextTrimming="CharacterEllipsis" />
                </Border>
            </StackPanel>

            <!-- Java path TextBlock -->
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Margin="6,0,6,0"
                       Text="{Binding JavaPath}"
                       TextTrimming="CharacterEllipsis" />

            <!-- More options button -->
            <Button x:Name="MoreOptionsButton"
                    Grid.RowSpan="2"
                    Grid.Column="2"
                    Width="32"
                    Height="32"
                    Padding="0"
                    HorizontalAlignment="Right"
                    IsHitTestVisible="False"
                    Opacity="0">
                <Button.Flyout>
                    <MenuFlyout>
                        <!-- View local folder MenuFlyoutItem -->
                        <MenuFlyoutItem x:Uid="JavaContentDialog_LocalViewMenuFlyoutItem"
                                        Command="{Binding DataContext.LocalViewJavaCommand, ElementName=JavaEntryListView}"
                                        CommandParameter="{Binding JavaPath}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xED25;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>

                        <MenuFlyoutSeparator />

                        <!-- Delete item MenuFlyoutItem -->
                        <MenuFlyoutItem x:Uid="JavaContentDialog_DeleteJavaMenuFlyoutItem"
                                        Command="{Binding DataContext.DeleteJavaCommand, ElementName=JavaEntryListView}"
                                        CommandParameter="{Binding JavaPath}"
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>

                <FontIcon FontSize="16" Glyph="&#xE712;" />
            </Button>
        </Grid>
    </DataTemplate>
</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Interactivity="using:Microsoft.Xaml.Interactivity">
    <DataTemplate x:Key="MinecraftFolderItemsTemplateSecondary">
        <StackPanel Grid.Column="0"
                    Height="20"
                    Orientation="Horizontal"
                    Spacing="8"
                    ToolTipService.ToolTip="{Binding MinecraftFolderPath}">
            <TextBlock Margin="4,0"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Text="{Binding MinecraftFolderId}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding MinecraftFolderPath}"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="MinecraftFolderItemsTemplatePrimary">
        <Grid Height="52"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>

            <Interactivity:Interaction.Behaviors>
                <Interactivity:EventTriggerBehavior EventName="PointerEntered">
                    <Interactivity:ChangePropertyAction PropertyName="Opacity"
                                                        TargetObject="{Binding ElementName=MoreOptionsButton}"
                                                        Value="1" />
                    <Interactivity:ChangePropertyAction PropertyName="IsHitTestVisible"
                                                        TargetObject="{Binding ElementName=MoreOptionsButton}"
                                                        Value="True" />
                </Interactivity:EventTriggerBehavior>
                <Interactivity:EventTriggerBehavior EventName="PointerExited">
                    <Interactivity:ChangePropertyAction PropertyName="Opacity"
                                                        TargetObject="{Binding ElementName=MoreOptionsButton}"
                                                        Value="0" />
                    <Interactivity:ChangePropertyAction PropertyName="IsHitTestVisible"
                                                        TargetObject="{Binding ElementName=MoreOptionsButton}"
                                                        Value="False" />
                </Interactivity:EventTriggerBehavior>
            </Interactivity:Interaction.Behaviors>

            <StackPanel Grid.Column="0"
                        Height="32"
                        Margin="0,8"
                        Orientation="Horizontal"
                        Spacing="8">
                <Border VerticalAlignment="Center"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4">
                    <TextBlock Margin="6,4"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Text="{Binding MinecraftFolderId}"
                               TextTrimming="CharacterEllipsis" />
                </Border>
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding MinecraftFolderPath}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- More options button -->
            <Button x:Name="MoreOptionsButton"
                    Grid.Column="1"
                    Width="32"
                    Height="32"
                    Padding="0"
                    HorizontalAlignment="Right"
                    IsHitTestVisible="False"
                    Opacity="0">
                <Button.Flyout>
                    <MenuFlyout>
                        <!-- View local folder MenuFlyoutItem -->
                        <MenuFlyoutItem x:Uid="/ViewResources/MinecraftFolderContentDialog_LocalViewMenuFlyoutItem"
                                        Command="{Binding DataContext.ViewFolderInLocalCommand, ElementName=MinecraftFolderEntryListView}"
                                        CommandParameter="{Binding MinecraftFolderPath}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xED25;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>

                        <!-- Rename item MenuFlyoutItem -->
                        <MenuFlyoutItem x:Uid="/ViewResources/MinecraftFolderContentDialog_RenameMinecraftFolderMenuFlyoutItem"
                                        Command="{Binding DataContext.RenameItemCommand, ElementName=MinecraftFolderEntryListView}"
                                        CommandParameter="{Binding MinecraftFolderPath}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8AC;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>

                        <MenuFlyoutSeparator />

                        <!-- Delete item MenuFlyoutItem -->
                        <MenuFlyoutItem x:Uid="/ViewResources/MinecraftFolderContentDialog_DeleteMinecraftFolderMenuFlyoutItem"
                                        Command="{Binding DataContext.DeleteItemCommand, ElementName=MinecraftFolderEntryListView}"
                                        CommandParameter="{Binding MinecraftFolderPath}"
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
                <FontIcon FontSize="16" Glyph="&#xE712;" />
            </Button>
        </Grid>
    </DataTemplate>
</ResourceDictionary>

<ContentDialog x:Class="BadMC_Launcher.Views.ContentDialogs.Settings.BackgroundImageContentDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:Interactivity="using:Microsoft.Xaml.Interactivity"
               xmlns:animations="using:CommunityToolkit.WinUI.Animations"
               xmlns:controls="using:CommunityToolkit.WinUI.Controls"
               xmlns:converters="using:CommunityToolkit.WinUI.Converters"
               xmlns:local="using:BadMC_Launcher.Views.ContentDialogs.Settings"
               xmlns:userConverters="using:BadMC_Launcher.Controls.Converters"
               x:Uid="/ViewResources/BackgroundImageContentDialog_ContentDialog"
               PrimaryButtonStyle="{ThemeResource AccentButtonStyle}"
               Style="{ThemeResource DefaultContentDialogStyle}">
    <ContentDialog.Resources>
        <userConverters:StringPathToImageConverter x:Key="StringPathToImageConverter" />

        <animations:ImplicitAnimationSet x:Name="ShowTransitions">
            <animations:OffsetAnimation EasingMode="EaseOut"
                                        From="0,24,0"
                                        To="0"
                                        Duration="0:0:0.4" />
            <animations:OpacityAnimation EasingMode="EaseOut"
                                         From="0"
                                         To="1"
                                         Duration="0:0:0.2" />
        </animations:ImplicitAnimationSet>
        <animations:ImplicitAnimationSet x:Name="HideTransitions">
            <animations:OffsetAnimation EasingMode="EaseOut"
                                        From="0"
                                        To="0,24,0"
                                        Duration="0:0:0.2" />
            <animations:OpacityAnimation EasingMode="EaseOut"
                                         From="1"
                                         To="0"
                                         Duration="0:0:0.1" />
        </animations:ImplicitAnimationSet>
    </ContentDialog.Resources>
    <Grid>
        <controls:SwitchPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  TargetType="x:Int32"
                                  Value="{Binding BackgroundNames.Count}">
            <controls:Case Value="0">
                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            animations:Implicit.HideAnimations="{StaticResource HideTransitions}"
                            animations:Implicit.ShowAnimations="{StaticResource ShowTransitions}"
                            Spacing="8">
                    <!-- Animation -->
                    <FontIcon HorizontalAlignment="Center"
                              FontSize="40"
                              Glyph="&#xEE71;" />
                    <TextBlock x:Uid="/ViewResources/BackgroundImageContentDialog_StaticImagesEmptyTitle_TextBlock"
                               HorizontalAlignment="Center"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Uid="/ViewResources/BackgroundImageContentDialog_StaticImagesEmptySubTitle_TextBlock" HorizontalAlignment="Center" />
                </StackPanel>
            </controls:Case>
            <controls:Case IsDefault="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="120" />
                    </Grid.RowDefinitions>

                    <!-- ViewImage -->
                    <FlipView x:Name="ImageView"
                              ItemsSource="{Binding BackgroundNames}"
                              SelectedItem="{Binding BackgroundName, Mode=TwoWay}">
                        <FlipView.ItemTemplate>
                            <DataTemplate>
                                <Image HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Source="{Binding Converter={StaticResource StringPathToImageConverter}}"
                                       Stretch="UniformToFill" />
                            </DataTemplate>
                        </FlipView.ItemTemplate>
                    </FlipView>

                    <!-- Images -->
                    <GridView animations:Implicit.HideAnimations="{StaticResource HideTransitions}"
                              animations:Implicit.ShowAnimations="{StaticResource ShowTransitions}"
                              ItemsSource="{Binding BackgroundNames}"
                              SelectedItem="{Binding BackgroundName, Mode=TwoWay}">
                        <!-- Styles -->
                        <GridView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource DefaultGridViewItemStyle}" TargetType="GridViewItem">
                                <Setter Property="Margin" Value="4,4,4,4" />
                            </Style>
                        </GridView.ItemContainerStyle>

                        <!-- Template -->
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Border Width="80"
                                        Height="80"
                                        Margin="2"
                                        CornerRadius="4">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding Converter={StaticResource StringPathToImageConverter}}" />
                                    </Border.Background>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>

                        <!-- SelectionChanged Event -->
                        <Interactivity:Interaction.Behaviors>
                            <Interactivity:EventTriggerBehavior EventName="SelectionChanged">
                                <Interactivity:InvokeCommandAction Command="{Binding SetBackgroundImageCommand}" CommandParameter="{Binding SelectedItem, ElementName=MonetColorsGridView}" />
                            </Interactivity:EventTriggerBehavior>
                        </Interactivity:Interaction.Behaviors>
                    </GridView>
                </Grid>

            </controls:Case>
        </controls:SwitchPresenter>
    </Grid>
</ContentDialog>

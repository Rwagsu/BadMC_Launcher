<ContentDialog x:Class="BadMC_Launcher.Views.ContentDialogs.Settings.JvmArgumentsContentDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:Interactivity="using:Microsoft.Xaml.Interactivity"
               xmlns:controls="using:CommunityToolkit.WinUI.Controls"
               xmlns:converters="using:CommunityToolkit.WinUI.Converters"
               xmlns:local="using:BadMC_Launcher.Views.ContentDialogs.Settings"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               x:Uid="JvmArgumentsContentDialog_ViewContentDialog"
               PrimaryButtonStyle="{StaticResource AccentButtonStyle}"
               Style="{ThemeResource DefaultContentDialogStyle}">
    <ContentDialog.Resources>
        <converters:BoolToObjectConverter x:Key="BoolToOpacityConverter"
                                          FalseValue="0"
                                          TrueValue="1" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ContentDialog.Resources>
    <Grid x:Name="JvmArgumentsList"
          Grid.Column="0"
          MinWidth="400"
          MinHeight="300"
          MaxWidth="600"
          MaxHeight="360">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="42" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0"
                      HorizontalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Auto"
                      IsVerticalScrollChainingEnabled="False">
            <ListView x:Name="JvmArgmentsListView" ItemsSource="{Binding JvmArgments}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="48" ToolTipService.ToolTip="{Binding TipText}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="42" />
                            </Grid.ColumnDefinitions>
                            <IconSourceElement Grid.Column="0"
                                               Width="24"
                                               Height="24"
                                               VerticalAlignment="Center"
                                               IconSource="{Binding ViewIcon}" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Text="{Binding Argument}" />
                            <Button x:Name="DeleteItemButton"
                                    Grid.Column="2"
                                    Width="34"
                                    Height="34"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.DeleteJvmArgmentCommand, ElementName=JvmArgmentsListView}"
                                    CommandParameter="{Binding}">

                                <FontIcon FontSize="16"
                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                          Glyph="&#xE74D;" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="{Binding IsJvmArgmentsEmpty}"
                    Opacity="{Binding IsJvmArgmentsEmpty, Converter={StaticResource BoolToOpacityConverter}}"
                    Spacing="8"
                    Visibility="{Binding IsJvmArgmentsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
            <!-- Animation -->
            <StackPanel.OpacityTransition>
                <ScalarTransition />
            </StackPanel.OpacityTransition>
            <FontIcon HorizontalAlignment="Center"
                      FontSize="40"
                      Glyph="&#xE8F6;" />
            <TextBlock x:Uid="JvmArgumentsContentDialog_JvmArgmentsEmptyTipsTitleTextBlock"
                       HorizontalAlignment="Center"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <TextBlock x:Uid="JvmArgumentsContentDialog_JvmArgmentsEmptyTipsMessageTextBlock" HorizontalAlignment="Center" />
        </StackPanel>

        <AutoSuggestBox x:Name="AddJvmArgumentsAutoSuggestBox"
                        x:Uid="JvmArgumentsContentDialog_JvmJvmArgumentsTokenizingTextBox"
                        Grid.Row="1"
                        Height="32"
                        MinWidth="200"
                        ItemsSource="{Binding DefaultJvmArgments, Mode=OneWay}"
                        Text="{Binding JvmArgmentText, Mode=TwoWay}">
            <AutoSuggestBox.QueryIcon>
                <FontIcon FontSize="16" Glyph="&#xE710;" />
            </AutoSuggestBox.QueryIcon>

            <AutoSuggestBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                ToolTipService.ToolTip="{Binding TipText}">
                        <IconSourceElement Width="24"
                                           Height="24"
                                           VerticalAlignment="Center"
                                           IconSource="{Binding ViewIcon}" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding Argument}" />
                    </StackPanel>
                </DataTemplate>
            </AutoSuggestBox.ItemTemplate>

            <Interactivity:Interaction.Behaviors>
                <Interactivity:EventTriggerBehavior EventName="QuerySubmitted">
                    <Interactivity:InvokeCommandAction Command="{Binding AddJvmArgumentCommand}" />
                </Interactivity:EventTriggerBehavior>

                <Interactivity:EventTriggerBehavior EventName="SuggestionChosen">
                    <Interactivity:InvokeCommandAction Command="{Binding AddJvmArgumentFromItemCommand}" />
                </Interactivity:EventTriggerBehavior>
            </Interactivity:Interaction.Behaviors>
        </AutoSuggestBox>

    </Grid>
</ContentDialog>

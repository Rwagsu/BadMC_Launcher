<ContentDialog x:Class="BadMC_Launcher.Views.ContentDialogs.Settings.MinecraftFolderContentDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:Interactivity="using:Microsoft.Xaml.Interactivity"
               xmlns:converters="using:CommunityToolkit.WinUI.Converters"
               xmlns:local="using:BadMC_Launcher.Views.ContentDialogs.Settings"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               x:Uid="MinecraftFolderContentDialog_ViewContentDialog"
               PrimaryButtonStyle="{StaticResource AccentButtonStyle}"
               Style="{ThemeResource DefaultContentDialogStyle}">
    <ContentDialog.Resources>
        <converters:BoolToObjectConverter x:Key="BoolToIntIsMinecraftFolderListEmptyonverter"
                                          FalseValue="0"
                                          TrueValue="1" />
    </ContentDialog.Resources>

    <Grid MinWidth="400" MinHeight="350">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ToolBar -->
        <Button x:Name="AddMinecraftFolderButton"
                Grid.Row="0"
                Height="36"
                Padding="0"
                HorizontalAlignment="Center"
                Command="{Binding AddMinecraftFolderCommand}">

            <!-- Rename Flyout -->
            <FlyoutBase.AttachedFlyout>
                <Flyout x:Name="RenameFlyout" Placement="Bottom">
                    <Interactivity:Interaction.Behaviors>
                        <Interactivity:EventTriggerBehavior EventName="Closed">
                            <Interactivity:InvokeCommandAction Command="{Binding DeleteRenameFlyoutDataCommand}" />
                        </Interactivity:EventTriggerBehavior>

                        <Interactivity:EventTriggerBehavior EventName="Opened">
                            <Interactivity:InvokeCommandAction Command="{Binding SetCanRenameCommand}" />
                        </Interactivity:EventTriggerBehavior>
                    </Interactivity:Interaction.Behaviors>
                    <StackPanel Grid.Row="0"
                                Width="300"
                                Margin="0,8"
                                Spacing="8">
                        <!-- Title TextBlock -->
                        <TextBlock x:Uid="MinecraftFolderContentDialog_ItemRenameTextBlock" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                        <StackPanel Spacing="4">
                            <!-- Rename TextBox -->
                            <TextBox x:Name="RenameTextBox"
                                     PlaceholderText="{Binding OldRenameMinecraftFolderId}"
                                     Style="{ThemeResource BodyStrongTextBlockStyle}"
                                     Text="{Binding NewRenameMinecraftFolderId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <Interactivity:Interaction.Behaviors>
                                    <Interactivity:EventTriggerBehavior EventName="TextChanged">
                                        <Interactivity:InvokeCommandAction Command="{Binding SetCanRenameCommand}" />
                                    </Interactivity:EventTriggerBehavior>
                                </Interactivity:Interaction.Behaviors>
                            </TextBox>

                            <!-- Rename error tip TextBlock -->
                            <TextBlock x:Name="RenameErrorTextBlock"
                                       x:Uid="MinecraftFolderContentDialog_ItemRenameErrorTextBlock"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Visibility="Collapsed" />

                            <!-- Set rename error state -->
                            <Interactivity:Interaction.Behaviors>
                                <!-- On can rename -->
                                <Interactivity:DataTriggerBehavior Binding="{Binding CanRename}"
                                                                   ComparisonCondition="Equal"
                                                                   Value="True">
                                    <Interactivity:ChangePropertyAction PropertyName="Visibility"
                                                                        TargetObject="{Binding ElementName=RenameErrorTextBlock}"
                                                                        Value="Collapsed" />
                                    <Interactivity:ChangePropertyAction PropertyName="BorderBrush"
                                                                        TargetObject="{Binding ElementName=RenameTextBox}"
                                                                        Value="{ThemeResource TextBoxBorderThemeBrush}" />
                                </Interactivity:DataTriggerBehavior>

                                <!-- On can't rename -->
                                <Interactivity:DataTriggerBehavior Binding="{Binding CanRename}"
                                                                   ComparisonCondition="Equal"
                                                                   Value="False">
                                    <Interactivity:ChangePropertyAction PropertyName="Visibility"
                                                                        TargetObject="{Binding ElementName=RenameErrorTextBlock}"
                                                                        Value="Visible" />
                                    <Interactivity:ChangePropertyAction PropertyName="BorderBrush"
                                                                        TargetObject="{Binding ElementName=RenameTextBox}"
                                                                        Value="{ThemeResource SystemFillColorCriticalBrush}" />
                                </Interactivity:DataTriggerBehavior>
                            </Interactivity:Interaction.Behaviors>
                        </StackPanel>

                        <!-- Rename Path TextBlock -->
                        <TextBlock x:Uid="MinecraftFolderContentDialog_ItemRenamePathTextBlock" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                        <HyperlinkButton x:Uid="MinecraftFolderContentDialog_ItemRenamePathHyperLinkButton"
                                         Command="{Binding OpenMinecraftFolderCommand}"
                                         Content="{Binding RenameMinecraftFolderPath}" />

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="8">
                            <!-- Apply Rename -->
                            <Button x:Name="ApplyRenameButton"
                                    x:Uid="MinecraftFolderContentDialog_ItemRenameApplyButton"
                                    Command="{Binding ApplyRenameCommand}"
                                    Style="{StaticResource AccentButtonStyle}" />

                            <!-- Cancel Rename -->
                            <Button x:Uid="MinecraftFolderContentDialog_ItemRenameCancelButton" Command="{Binding HideRenameFlyoutCommand}">
                                <Interactivity:Interaction.Behaviors>
                                    <Interactivity:EventTriggerBehavior EventName="Click">
                                        <Interactivity:CallMethodAction MethodName="" />
                                    </Interactivity:EventTriggerBehavior>
                                </Interactivity:Interaction.Behaviors>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Flyout>
            </FlyoutBase.AttachedFlyout>
            <StackPanel Margin="8,0"
                        Orientation="Horizontal"
                        Spacing="8">
                <FontIcon Glyph="&#xE8F4;" />
                <TextBlock x:Uid="MinecraftFolderContentDialog_AddItemMenuButton" />
            </StackPanel>
        </Button>

        <!-- Items -->
        <ListView x:Name="MinecraftFolderEntryListView"
                  Grid.Row="1"
                  ItemTemplate="{StaticResource MinecraftFolderItemsTemplatePrimary}"
                  ItemsSource="{Binding MinecraftFoldersList}"
                  SelectedIndex="{Binding MinecraftFoldersListSelectedIndex, Mode=TwoWay}">
            <Interactivity:Interaction.Behaviors>
                <Interactivity:EventTriggerBehavior EventName="SelectionChanged">
                    <Interactivity:InvokeCommandAction Command="{Binding SetActiveMinecraftFolderCommand}" />
                </Interactivity:EventTriggerBehavior>
            </Interactivity:Interaction.Behaviors>
        </ListView>

        <!-- If there is no ontology in the list, a prompt is displayed. -->
        <StackPanel x:Name="MinecraftFolderEmptyTipsStackPanel"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="{Binding IsMinecraftFoldersListEmpty}"
                    Opacity="{Binding IsMinecraftFoldersListEmpty, Converter={StaticResource BoolToIntIsMinecraftFolderListEmptyonverter}}"
                    Spacing="8">
            <!-- Animation -->
            <StackPanel.OpacityTransition>
                <ScalarTransition />
            </StackPanel.OpacityTransition>
            <FontIcon HorizontalAlignment="Center"
                      FontSize="40"
                      Glyph="&#xE8F6;" />
            <TextBlock x:Uid="MinecraftFolderContentDialog_MinecraftFolderEmptyListTipsTextBlock"
                       HorizontalAlignment="Center"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <HyperlinkButton x:Uid="MinecraftFolderContentDialog_MinecraftFolderEmptyListTipsHyperLinkButton"
                             HorizontalAlignment="Center"
                             Command="{Binding AddMinecraftFolderCommand}" />
        </StackPanel>
    </Grid>
</ContentDialog>

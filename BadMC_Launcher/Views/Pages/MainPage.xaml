<Page x:Class="BadMC_Launcher.Views.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:Interactivity="using:Microsoft.Xaml.Interactivity"
      xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
      xmlns:animations="using:CommunityToolkit.WinUI.Animations"
      xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
      xmlns:converters="using:CommunityToolkit.WinUI.Converters"
      xmlns:labs="using:CommunityToolkit.Labs.WinUI"
      xmlns:local="using:BadMC_Launcher"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:skia="http://uno.ui/skia"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:userControls="using:BadMC_Launcher.Views.UserControls"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
      mc:Ignorable="skia">
    <Page.Resources>
        <converters:EmptyStringToObjectConverter x:Key="EmptyStringToBoolConverter"
                                                 EmptyValue="False"
                                                 NotEmptyValue="True" />
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds" Background="{Binding AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- TitleBar -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                <Button Width="36"
                        Height="36"
                        Style="{StaticResource ButtonTransparentStyle}">
                    <FontIcon Glyph="&#xE7C4;" />
                </Button>
                <Button Width="36"
                        Height="36"
                        Style="{StaticResource ButtonTransparentStyle}">
                    <ImageIcon Width="24"
                               Height="24"
                               Source="\Assets\Icons\appicon_foreground.png" />
                </Button>

                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="Bold"
                           Text="{Binding WindowName}" />
            </StackPanel>

            <!-- MenuFlyout -->
            <!--<FlyoutBase.AttachedFlyout>
                <Flyout x:Name="MainSideBarFlyout" Placement="TopEdgeAlignedLeft">
                    <Flyout.FlyoutPresenterStyle>
                        <Style TargetType="FlyoutPresenter">
                            <Setter Property="MaxWidth" Value="800" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="CornerRadius" Value="8" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="52,8,0,0" />
                        </Style>
                    </Flyout.FlyoutPresenterStyle>
                    <Interactivity:Interaction.Behaviors>
                        <Interactivity:EventTriggerBehavior EventName="Closed">
                            <Interactivity:InvokeCommandAction Command="{Binding DeselectItemCommand}" />
                        </Interactivity:EventTriggerBehavior>
                    </Interactivity:Interaction.Behaviors>
                    <Frame x:Name="MainSideBarFlyoutFrame"
                           Width="700"
                           Height="544" />
                </Flyout>
            </FlyoutBase.AttachedFlyout>-->
        </Border>

        <!-- DashBoard -->
        <Grid Grid.Row="1"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <!-- SideBar -->
            <NavigationView x:Name="MainSideBar"
                            x:Uid="MainPage_MainSideBarNavigationView"
                            Margin="-1"
                            FooterMenuItemsSource="{Binding MainSideBarFooterItems}"
                            IsBackButtonVisible="Collapsed"
                            IsSettingsVisible="False"
                            MenuItemsSource="{Binding MainSideBarItems}"
                            PaneDisplayMode="LeftCompact"
                            SelectedItem="{Binding MainSideBarSelectedItem, Mode=TwoWay}">

                <!-- SideBar Styles -->
                <NavigationView.Resources>
                    <StaticResource x:Key="NavigationViewExpandedPaneBackground" ResourceKey="AcrylicInAppFillColorDefaultBrush" />
                    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                </NavigationView.Resources>

                <NavigationView.AutoSuggestBox>
                    <!-- Search Box -->
                    <AutoSuggestBox x:Uid="MainPage_SearchResource"
                                    x:Name="SearchAutoSuggestBox"
                                    ItemTemplate="{StaticResource MainMenuSearchItemTemplate}"
                                    ItemsSource="{Binding SearchItems, Mode=TwoWay}"
                                    Text="{Binding SearchText, Mode=TwoWay}">
                        <AutoSuggestBox.QueryIcon>
                            <FontIcon Glyph="&#xE71C;" />
                        </AutoSuggestBox.QueryIcon>

                        <Interactivity:Interaction.Behaviors>
                            <!-- SearchButton Clicked Event -->
                            <Interactivity:EventTriggerBehavior EventName="QuerySubmitted">
                                <Interactivity:InvokeCommandAction Command="{Binding OpenSearchFilterCommand}" CommandParameter="{Binding ElementName=SearchAutoSuggestBox}"/>
                            </Interactivity:EventTriggerBehavior>

                            <!-- SearchItem Selected Event -->
                            <Interactivity:EventTriggerBehavior EventName="SuggestionChosen">
                                <Interactivity:InvokeCommandAction Command="{Binding SearchItemNavigateToPageCommand}" />
                            </Interactivity:EventTriggerBehavior>

                            <!-- Text Changed Event -->
                            <Interactivity:EventTriggerBehavior EventName="TextChanged">
                                <Interactivity:InvokeCommandAction Command="{Binding SearchItemCommand}" />
                            </Interactivity:EventTriggerBehavior>
                        </Interactivity:Interaction.Behaviors>

                        <!-- Search Filter Button -->
                        <FlyoutBase.AttachedFlyout>
                            <Flyout>
                                <StackPanel Spacing="16">
                                    <!-- Tags Head -->
                                    <StackPanel x:Uid="Global_BetaTipResource"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock x:Uid="MainPage_SearchFilterTagsResource" FontWeight="Bold" />
                                        <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}" CornerRadius="4">
                                            <TextBlock Margin="8,0"
                                                       FontWeight="Bold"
                                                       Text="BETA" />
                                        </Border>
                                    </StackPanel>
                                    <!-- Select Tags -->
                                    <labs:TokenView x:Name="SearchFilterTokenView"
                                                    IsWrapped="True"
                                                    ItemsSource="{Binding SearchFilterItems, Mode=TwoWay}"
                                                    SelectionMode="Multiple">
                                        <labs:TokenView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="8,0"
                                                            Orientation="Horizontal"
                                                            Spacing="8">
                                                    <FontIcon VerticalAlignment="Center" Glyph="{Binding IconGlyph}" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Text="{Binding ItemName}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </labs:TokenView.ItemTemplate>

                                        <!-- SearchTags Selected Event -->
                                        <Interactivity:Interaction.Behaviors>
                                            <Interactivity:EventTriggerBehavior EventName="SelectionChanged">
                                                <Interactivity:InvokeCommandAction Command="{Binding ChangeSearchFilterCommand}" CommandParameter="{Binding SelectedItems, ElementName=SearchFilterTokenView}" />
                                            </Interactivity:EventTriggerBehavior>
                                        </Interactivity:Interaction.Behaviors>
                                    </labs:TokenView>
                                </StackPanel>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                    </AutoSuggestBox>
                </NavigationView.AutoSuggestBox>


                <!-- MenuItem Template -->
                <NavigationView.MenuItemTemplate>
                    <DataTemplate>
                        <NavigationViewItem Content="{Binding ItemName}"
                                            Icon="{Binding ItemIcon}"
                                            InfoBadge="{Binding ItemInfoBadge}" />
                    </DataTemplate>
                </NavigationView.MenuItemTemplate>

                <Interactivity:Interaction.Behaviors>
                    <Interactivity:EventTriggerBehavior EventName="SelectionChanged">
                        <Interactivity:InvokeCommandAction Command="{Binding NavigateToPageCommand}" />
                    </Interactivity:EventTriggerBehavior>
                </Interactivity:Interaction.Behaviors>

                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="336" />
                    </Grid.ColumnDefinitions>

                    <!-- Page Frame -->
                    <Grid x:Name="MainFrameGrid"
                          Grid.Column="0"
                          Margin="0,0,16,0"
                          Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                          CornerRadius="8"
                          Visibility="Collapsed">
                        <!-- Frame Animation -->
                        <animations:Explicit.Animations>

                            <!-- Frame Navigated -->
                            <animations:AnimationSet x:Name="FrameInAnimation">
                                <animations:OpacityAnimation From="0"
                                                             To="1"
                                                             Duration="0:0:0.6" />
                                <animations:TranslationAnimation EasingMode="EaseOut"
                                                                 EasingType="Circle"
                                                                 From="0,150,0"
                                                                 To="0"
                                                                 Duration="0:0:0.6" />
                            </animations:AnimationSet>

                            <!-- Frame Closed -->
                            <animations:AnimationSet x:Name="FrameOutAnimation">
                                <animations:OpacityAnimation EasingMode="EaseIn"
                                                             EasingType="Circle"
                                                             From="1"
                                                             To="0"
                                                             Duration="0:0:0.2" />
                                <animations:TranslationAnimation EasingMode="EaseIn"
                                                                 EasingType="Circle"
                                                                 From="0"
                                                                 To="0,150,0"
                                                                 Duration="0:0:0.2" />

                                <!-- Animation Behaviors -->
                                <Interactivity:Interaction.Behaviors>
                                    <behaviors:AnimationCompletedTriggerBehavior>
                                        <Interactivity:ChangePropertyAction PropertyName="Visibility"
                                                                            TargetObject="{Binding ElementName=MainFrameGrid}"
                                                                            Value="Collapsed" />
                                    </behaviors:AnimationCompletedTriggerBehavior>
                                </Interactivity:Interaction.Behaviors>
                            </animations:AnimationSet>
                        </animations:Explicit.Animations>

                        <Frame x:Name="MainSideBarFrame">
                            <Interactivity:Interaction.Behaviors>
                                <!-- Frame Navigated -->
                                <Interactivity:DataTriggerBehavior Binding="{Binding Content, ElementName=MainSideBarFrame, Converter={StaticResource EmptyStringToBoolConverter}}"
                                                                   ComparisonCondition="Equal"
                                                                   Value="True">
                                    <Interactivity:ChangePropertyAction PropertyName="Visibility"
                                                                        TargetObject="{Binding ElementName=MainFrameGrid}"
                                                                        Value="Visible" />
                                    <behaviors:StartAnimationAction Animation="{Binding ElementName=FrameInAnimation}" />
                                </Interactivity:DataTriggerBehavior>

                                <!-- Frame Closed -->
                                <Interactivity:DataTriggerBehavior Binding="{Binding Content, ElementName=MainSideBarFrame, Converter={StaticResource EmptyStringToBoolConverter}}"
                                                                   ComparisonCondition="Equal"
                                                                   Value="False">
                                    <Interactivity:InvokeCommandAction Command="{Binding ChangeToolVisibilityAndSelectedItemCommand}" CommandParameter="{Binding ElementName=MainSideBarFrame}" />
                                    <behaviors:StartAnimationAction Animation="{Binding ElementName=FrameOutAnimation}" />
                                </Interactivity:DataTriggerBehavior>

                                <!-- Frame Navigated Event -->
                                <Interactivity:EventTriggerBehavior EventName="Navigated">
                                    <Interactivity:InvokeCommandAction Command="{Binding ChangeToolVisibilityAndSelectedItemCommand}" CommandParameter="{Binding ElementName=MainSideBarFrame}" />
                                </Interactivity:EventTriggerBehavior>
                            </Interactivity:Interaction.Behaviors>
                        </Frame>

                        <!-- PageFrame Button -->
                        <StackPanel x:Name="MainSideBarPageMenu"
                                    Margin="4"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    Visibility="{Binding MainSideBarToolVisibility}">
                            <!-- Back to Page -->
                            <HyperlinkButton Width="36"
                                             Height="36"
                                             Padding="0"
                                             Command="{Binding PageGoBackCommand}"
                                             CommandParameter="{Binding ElementName=MainSideBarFrame}">
                                <AnimatedIcon x:Name="SearchAnimatedIcon"
                                              Width="18"
                                              Height="18">
                                    <AnimatedIcon.FallbackIconSource>
                                        <FontIconSource FontSize="16" Glyph="&#xE72B;" />
                                    </AnimatedIcon.FallbackIconSource>
                                    <AnimatedIcon.Source>
                                        <animatedvisuals:AnimatedBackVisualSource />
                                    </AnimatedIcon.Source>
                                </AnimatedIcon>
                            </HyperlinkButton>

                            <!-- Close Page -->
                            <Button Width="36"
                                    Height="36"
                                    Command="{Binding ClosePageCommand}"
                                    CommandParameter="{Binding ElementName=MainSideBarFrame}"
                                    Style="{StaticResource ButtonTransparentStyle}">
                                <FontIcon Width="16"
                                          Height="16"
                                          FontSize="14"
                                          Glyph="&#xE711;" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- LaunchPad -->
                    <userControls:LaunchPad Grid.Column="1"
                                            Width="336"
                                            HorizontalAlignment="Right" />
                </Grid>
            </NavigationView>
        </Grid>
    </Grid>
</Page>

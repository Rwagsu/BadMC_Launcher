<Page x:Class="BadMC_Launcher.Views.Pages.Settings.ThemeSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:Interactivity="using:Microsoft.Xaml.Interactivity"
      xmlns:animations="using:CommunityToolkit.WinUI.Animations"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      xmlns:converters="using:CommunityToolkit.WinUI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:BadMC_Launcher.Views.Pages.Settings"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:userConverters="using:BadMC_Launcher.Controls.Converters"
      mc:Ignorable="d">
    <Page.Resources>
        <userConverters:ThemeTypeToIndexConverter x:Key="ThemeTypeToIndexConverter" />
        <userConverters:AccentColorModeToIndexConverter x:Key="AccentColorModeToIndexConverter" />
        <userConverters:HexToColorConverter x:Key="HexToColorConverter" />
        <converters:ColorToDisplayNameConverter x:Key="ColorToDisplayNameConverter" />

        <animations:ImplicitAnimationSet x:Name="ShowTransitions">
            <animations:OffsetAnimation EasingMode="EaseOut"
                                        From="0,24,0"
                                        To="0"
                                        Duration="0:0:0.4" />
            <animations:OpacityAnimation EasingMode="EaseOut"
                                         From="0"
                                         To="1"
                                         Duration="0:0:0.2" />
        </animations:ImplicitAnimationSet>
        <animations:ImplicitAnimationSet x:Name="HideTransitions">
            <animations:OffsetAnimation EasingMode="EaseOut"
                                        From="0"
                                        To="0,24,0"
                                        Duration="0:0:0.2" />
            <animations:OpacityAnimation EasingMode="EaseOut"
                                         From="1"
                                         To="0"
                                         Duration="0:0:0.1" />
        </animations:ImplicitAnimationSet>

    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="18,12" Spacing="8">
            <!-- Color Theme setting -->
            <controls:SettingsCard x:Uid="/ViewResources/ThemeSettingsPage_ColorThemeSettingsCard">
                <!-- Icons -->
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE793;" />
                </controls:SettingsCard.HeaderIcon>

                <!-- Content -->
                <controls:Segmented SelectedIndex="{Binding ThemeType, Converter={StaticResource ThemeTypeToIndexConverter}, Mode=TwoWay}">
                    <Interactivity:Interaction.Behaviors>
                        <Interactivity:EventTriggerBehavior EventName="SelectionChanged">
                            <Interactivity:InvokeCommandAction Command="{Binding SetThemeTypeCommand}" />
                        </Interactivity:EventTriggerBehavior>
                    </Interactivity:Interaction.Behaviors>

                    <!-- System -->
                    <controls:SegmentedItem x:Uid="/ViewResources/ThemeSettingsPage_ColorThemes_System">
                        <controls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xE770;" />
                        </controls:SegmentedItem.Icon>
                    </controls:SegmentedItem>

                    <!-- Light -->
                    <controls:SegmentedItem x:Uid="/ViewResources/ThemeSettingsPage_ColorThemes_Light">
                        <controls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xE781;" />
                        </controls:SegmentedItem.Icon>
                    </controls:SegmentedItem>

                    <!-- Dark -->
                    <controls:SegmentedItem x:Uid="/ViewResources/ThemeSettingsPage_ColorThemes_Dark">
                        <controls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xE793;" />
                        </controls:SegmentedItem.Icon>
                    </controls:SegmentedItem>
                </controls:Segmented>
            </controls:SettingsCard>

            <!-- Accent color setting -->
            <controls:SettingsExpander x:Uid="/ViewResources/ThemeSettingsPage_AccentColorSettingsExpander">
                <!-- Icons -->
                <controls:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE790;" />
                </controls:SettingsExpander.HeaderIcon>

                <!-- Items -->
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard x:Uid="/ViewResources/ThemeSettingsPage_AccentColorMode_SettingsCard">
                        <!-- Icons -->
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE895;" />
                        </controls:SettingsCard.HeaderIcon>

                        <!-- Content -->
                        <ComboBox x:Name="AccentColorModeComboBox" SelectedIndex="{Binding AccentColorMode, Converter={StaticResource AccentColorModeToIndexConverter}, Mode=TwoWay}">
                            <!-- System -->
                            <ComboBoxItem x:Uid="/ViewResources/ThemeSettingsPage_AccentColorThemes_SystemTips">
                                <StackPanel Padding="0,2"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                    <FontIcon Width="24"
                                              Height="24"
                                              VerticalAlignment="Center"
                                              Glyph="&#xE770;" />
                                    <TextBlock x:Uid="/ViewResources/ThemeSettingsPage_AccentColorThemes_System"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </ComboBoxItem>

                            <!-- Custom -->
                            <ComboBoxItem x:Uid="/ViewResources/ThemeSettingsPage_AccentColorThemes_CustomTips">
                                <StackPanel Padding="0,2"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                    <FontIcon Width="24"
                                              Height="24"
                                              VerticalAlignment="Center"
                                              Glyph="&#xE790;" />
                                    <TextBlock x:Uid="/ViewResources/ThemeSettingsPage_AccentColorThemes_Custom"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </ComboBoxItem>

                            <!-- ImageMonet -->
                            <ComboBoxItem x:Uid="/ViewResources/ThemeSettingsPage_AccentColorThemes_ImageMonetTips">
                                <StackPanel Padding="0,2"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                    <FontIcon Width="24"
                                              Height="24"
                                              VerticalAlignment="Center"
                                              Glyph="&#xEE71;" />
                                    <TextBlock x:Uid="/ViewResources/ThemeSettingsPage_AccentColorThemes_ImageMonet"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </ComboBoxItem>

                            <!-- ColorMonet -->
                            <ComboBoxItem x:Uid="/ViewResources/ThemeSettingsPage_AccentColorThemes_ColorMonetTips">
                                <StackPanel Padding="0,2"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                    <FontIcon Width="24"
                                              Height="24"
                                              VerticalAlignment="Center"
                                              Glyph="&#xE794;" />
                                    <TextBlock x:Uid="/ViewResources/ThemeSettingsPage_AccentColorThemes_ColorMonet"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>
                    </controls:SettingsCard>
                    <controls:SettingsCard Description="{x:Bind GetAccentSettingsCardDescription(AccentColorModeComboBox.SelectedIndex), Mode=OneWay}"
                                           Header="{x:Bind GetAccentSettingsCardHeader(AccentColorModeComboBox.SelectedIndex), Mode=OneWay}"
                                           HeaderIcon="{x:Bind GetAccentSettingsCardIcon(AccentColorModeComboBox.SelectedIndex), Mode=OneWay}">
                        <controls:SwitchPresenter TargetType="x:Int32" Value="{Binding SelectedIndex, ElementName=AccentColorModeComboBox, Mode=OneWay}">
                            <controls:Case Value="0">
                                <Image animations:Implicit.HideAnimations="{StaticResource HideTransitions}" animations:Implicit.ShowAnimations="{StaticResource ShowTransitions}" />
                            </controls:Case>
                            <controls:Case Value="1">
                                <controls:ColorPickerButton SelectedColor="{Binding AccentColorHex, Mode=TwoWay, Converter={StaticResource HexToColorConverter}}">
                                    <Interactivity:Interaction.Behaviors>
                                        <Interactivity:EventTriggerBehavior EventName="LosingFocus">
                                            <Interactivity:InvokeCommandAction Command="{Binding SetAccentColorHexCommand}" />
                                        </Interactivity:EventTriggerBehavior>
                                    </Interactivity:Interaction.Behaviors>
                                </controls:ColorPickerButton>
                            </controls:Case>
                            <controls:Case Value="2">
                                <GridView x:Name="MonetColorsGridView" ItemsSource="{Binding ImageMonetColors}">
                                    <!-- Styles -->
                                    <GridView.ItemContainerStyle>
                                        <Style BasedOn="{StaticResource DefaultGridViewItemStyle}" TargetType="GridViewItem">
                                            <Setter Property="Margin" Value="4,4,4,4" />
                                        </Style>
                                    </GridView.ItemContainerStyle>

                                    <!-- Template -->
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="48"
                                                    Height="48"
                                                    Margin="2"
                                                    Background="{Binding}"
                                                    CornerRadius="4"
                                                    ToolTipService.ToolTip="{Binding Converter={StaticResource ColorToDisplayNameConverter}}" />
                                        </DataTemplate>
                                    </GridView.ItemTemplate>

                                    <!-- SelectionChanged Event -->
                                    <Interactivity:Interaction.Behaviors>
                                        <Interactivity:EventTriggerBehavior EventName="SelectionChanged">
                                            <Interactivity:InvokeCommandAction Command="{Binding SetMonetAndApplyCommand}" CommandParameter="{Binding SelectedItem, ElementName=MonetColorsGridView}" />
                                        </Interactivity:EventTriggerBehavior>
                                    </Interactivity:Interaction.Behaviors>
                                </GridView>
                            </controls:Case>
                            <controls:Case Value="3">
                                <controls:ColorPickerButton x:Name="MonetColorPickerButton" SelectedColor="{Binding ColorMonetColorHex, Mode=TwoWay, Converter={StaticResource HexToColorConverter}}">
                                    <Interactivity:Interaction.Behaviors>
                                        <Interactivity:EventTriggerBehavior EventName="LosingFocus">
                                            <Interactivity:InvokeCommandAction Command="{Binding SetMonetAndApplyCommand}" CommandParameter="{Binding SelectedColor, ElementName=MonetColorPickerButton}" />
                                        </Interactivity:EventTriggerBehavior>
                                    </Interactivity:Interaction.Behaviors>
                                </controls:ColorPickerButton>
                            </controls:Case>
                        </controls:SwitchPresenter>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>

                <!-- Content -->
                <Border Padding="8,4"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4"
                        ToolTipService.ToolTip="{Binding Path=Background, Converter={StaticResource ColorToDisplayNameConverter}}">
                    <TextBlock Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Text="{Binding ViewAccentColorHex}" />
                </Border>
            </controls:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</Page>

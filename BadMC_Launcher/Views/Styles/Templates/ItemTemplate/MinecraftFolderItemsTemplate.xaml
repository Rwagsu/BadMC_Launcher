<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Interactivity="using:Microsoft.Xaml.Interactivity">
    <DataTemplate x:Key="MinecraftFolderItemsTemplateSecondary">
        <StackPanel Height="20" ToolTipService.ToolTip="{Binding MinecraftFolderPath}">
            <TextBlock VerticalAlignment="Center"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Text="{Binding MinecraftFolderId}" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="MinecraftFolderItemsTemplatePrimary">
        <Grid Height="52"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="76" />
            </Grid.ColumnDefinitions>

            <Interactivity:Interaction.Behaviors>
                <Interactivity:EventTriggerBehavior EventName="PointerEntered">
                    <Interactivity:ChangePropertyAction PropertyName="Opacity"
                                                        TargetObject="{Binding ElementName=TTee}"
                                                        Value="1" />
                    <Interactivity:ChangePropertyAction PropertyName="IsHitTestVisible"
                                                        TargetObject="{Binding ElementName=TTee}"
                                                        Value="True" />
                </Interactivity:EventTriggerBehavior>
                <Interactivity:EventTriggerBehavior EventName="PointerExited">
                    <Interactivity:ChangePropertyAction PropertyName="Opacity"
                                                        TargetObject="{Binding ElementName=TTee}"
                                                        Value="0" />
                    <Interactivity:ChangePropertyAction PropertyName="IsHitTestVisible"
                                                        TargetObject="{Binding ElementName=TTee}"
                                                        Value="False" />
                </Interactivity:EventTriggerBehavior>
            </Interactivity:Interaction.Behaviors>

            <StackPanel Grid.Column="0"
                        Height="32"
                        Margin="0,8"
                        Orientation="Horizontal"
                        Spacing="8">
                <Border VerticalAlignment="Center"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4">
                    <TextBlock Margin="6,4"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Text="{Binding MinecraftFolderId}"
                               TextTrimming="CharacterEllipsis" />
                </Border>
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding MinecraftFolderPath}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel x:Name="TTee"
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Opacity="0"
                        Orientation="Horizontal"
                        Spacing="6">
                <!-- More options button -->
                <Button Width="32"
                        Height="32"
                        Padding="0">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Uid="MinecraftFolderContentDialog_LocalViewMenuFlyoutItem"
                                            Command="{Binding DataContext.ViewFolderInLocalCommand, ElementName=MinecraftFolderEntryListView}"
                                            CommandParameter="{Binding MinecraftFolderPath}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xED25;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>

                    <FontIcon FontSize="16" Glyph="&#xE712;" />
                </Button>
                <!-- DeleteItem button -->
                <Button Width="32"
                        Height="32"
                        Padding="0"
                        Background="{ThemeResource SystemFillColorCriticalBrush}">
                    <FontIcon FontSize="16"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                              Glyph="&#xE74D;" />
                </Button>
            </StackPanel>
        </Grid>
    </DataTemplate>
</ResourceDictionary>

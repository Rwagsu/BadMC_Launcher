<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DataTemplate x:Key="MinecraftFolderItemsTemplateSecondary">
        <StackPanel Height="20" ToolTipService.ToolTip="{Binding MinecraftFolderPath}">
            <TextBlock VerticalAlignment="Center"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Text="{Binding MinecraftId}" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="MinecraftFolderItemsTemplatePrimary">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="64" />
            </Grid.ColumnDefinitions>
            <StackPanel Height="48"
                        Margin="0,8"
                        Spacing="2">
                <TextBlock FontWeight="Bold"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           Text="{Binding MinecraftId}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock VerticalAlignment="Center"
                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                           Text="{Binding MinecraftFolderPath}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>
    </DataTemplate>
</ResourceDictionary>

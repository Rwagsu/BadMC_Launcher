<UserControl x:Class="BadMC_Launcher.Views.UserControls.Badge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:BadMC_Launcher.Views.UserControls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <!-- Tip -->
    <Border Background="{x:Bind SeverityToBrush(Severity), Mode=OneWay}" CornerRadius="4">
        <TextBlock Margin="8,4"
                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                   Text="{x:Bind Text, Mode=OneWay}" />
    </Border>
</UserControl>

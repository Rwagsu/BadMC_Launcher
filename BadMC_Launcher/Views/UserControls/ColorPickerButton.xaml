<UserControl x:Class="BadMC_Launcher.Views.UserControls.ColorPickerButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:animations="using:CommunityToolkit.WinUI.Animations"
             xmlns:controls="using:CommunityToolkit.WinUI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:BadMC_Launcher.Views.UserControls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:userConverters="using:BadMC_Launcher.Controls.Converters">
    <UserControl.Resources>
        <userConverters:HexToColorConverter x:Key="HexToColorConverter" />
    </UserControl.Resources>

    <Button>
        <Button.Content>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="16" Height="16">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{x:Bind SelectedColor, Mode=OneWay}" />
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="{x:Bind ColorToHex(SelectedColor), Mode=OneWay}" />
            </StackPanel>
        </Button.Content>

        <Button.Flyout>
            <!-- ColorPicker Flyout -->
            <Flyout x:Name="ColorPickerFlyout" Placement="Full">
                <Flyout.FlyoutPresenterStyle>
                    <Style TargetType="FlyoutPresenter">
                        <Setter Property="MaxHeight" Value="Infinity" />
                        <Setter Property="MaxWidth" Value="Infinity" />
                        <Setter Property="CornerRadius" Value="8" />
                    </Style>
                </Flyout.FlyoutPresenterStyle>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Translation="0,0,0">
                    <!-- Animations -->
                    <animations:Explicit.Animations>
                        <!-- Open animation -->
                        <animations:AnimationSet x:Name="ShowFlyoutAnimation">
                            <animations:TranslationAnimation EasingMode="EaseOut"
                                                             EasingType="Quintic"
                                                             To="0,0,0"
                                                             Duration="0:0:0.6" />
                        </animations:AnimationSet>

                        <!-- Close animation -->
                        <animations:AnimationSet x:Name="HideFlyoutAnimation">
                            <animations:TranslationAnimation EasingMode="EaseIn"
                                                             EasingType="Quartic"
                                                             To="0,60,0"
                                                             Duration="0:0:0.2" />
                        </animations:AnimationSet>
                    </animations:Explicit.Animations>

                    <!-- ColorPicker -->
                    <controls:ColorPicker x:Name="Picker"
                                          IsAlphaEnabled="False"
                                          Loaded="SetColorColorPicker_Loaded" />

                    <!-- Buttons -->
                    <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button x:Uid="/ViewResources/ColorPickerButton_Cancel_Button" Click="CancelButton_Click" />
                        <Button x:Uid="/ViewResources/ColorPickerButton_Apply_Button"
                                Click="ApplyButton_Click"
                                Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Flyout>
        </Button.Flyout>
    </Button>
</UserControl>

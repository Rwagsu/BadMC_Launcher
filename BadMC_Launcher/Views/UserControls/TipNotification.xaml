<UserControl x:Class="BadMC_Launcher.Views.UserControls.TipNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:animations="using:CommunityToolkit.WinUI.Animations"
             xmlns:local="using:BadMC_Launcher.Views.UserControls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             IsHitTestVisible="False"
             Loaded="OnControlLoaded"
             Translation="430,0,0">
    <!-- Animations -->
    <animations:Explicit.Animations>
        <!-- Open animation -->
        <animations:AnimationSet x:Name="OpenNotificationAnimation">
            <animations:TranslationAnimation EasingMode="EaseOut"
                                         EasingType="Quintic"
                                         To="-430,0,0"
                                         Duration="0:0:0.4" />
        </animations:AnimationSet>

        <!-- Close animation -->
        <animations:AnimationSet x:Name="CloseNotificationAnimation">
            <animations:TranslationAnimation EasingMode="EaseIn"
                                         EasingType="Quartic"
                                         To="0"
                                         Duration="0:0:0.3" />
        </animations:AnimationSet>
    </animations:Explicit.Animations>

    <Grid Padding="12"
          Background="{x:Bind NotificationItem.NotificationColor, Mode=OneWay}"
          CornerRadius="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="42" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Icon -->
            <IconSourceElement Grid.Column="0"
                               Width="36"
                               Height="36"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               IconSource="{x:Bind NotificationItem.NotificationIcon, Mode=OneWay}" />

            <!-- Title -->
            <TextBlock Grid.Column="1"
                       MaxWidth="160"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Text="{x:Bind NotificationItem.Title, Mode=OneWay}"
                       TextWrapping="Wrap" />

            <!-- Message -->
            <TextBlock Grid.Column="2"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                       Text="{x:Bind NotificationItem.Message, Mode=OneWay}"
                       TextWrapping="Wrap" />

        </Grid>

        <!-- Close Button -->
        <Button Grid.Column="1"
                Width="32"
                Height="32"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Click="OnCloseButtonClick"
                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                Style="{StaticResource ButtonTransparentStyle}">
            <Button.Resources>
                <!-- Pressed Colors -->
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                <StaticResource x:Key="ButtonForegroundPressed" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />

                <!-- PointerOver Colors -->
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                <StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
            </Button.Resources>
            <FontIcon FontSize="18" Glyph="&#xE711;" />
        </Button>
    </Grid>
</UserControl>
